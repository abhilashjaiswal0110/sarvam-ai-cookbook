# ------------------------------------------------------------------
# Sarvam AI Enterprise Use Cases — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to VCS.
# ------------------------------------------------------------------

# ── Sarvam AI ─────────────────────────────────────────────────────
SARVAM_API_KEY=your_sarvam_api_key_here

# ── Application Settings ──────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── Server ────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── Data Governance ───────────────────────────────────────────────
MASK_PII_IN_LOGS=true
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=logs/audit.log
MAX_LOG_RETENTION_DAYS=90
